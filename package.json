{
  "name": "claude-limit-monitor",
  "displayName": "Claude Limit Monitor",
  "description": "Monitor Anthropic API rate limit headers from Claude Code CLI traffic",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeLimitMonitor.start",
        "title": "Claude Limit Monitor: Start Proxy"
      },
      {
        "command": "claudeLimitMonitor.stop",
        "title": "Claude Limit Monitor: Stop Proxy"
      },
      {
        "command": "claudeLimitMonitor.showDashboard",
        "title": "Claude Limit Monitor: Show Dashboard"
      },
      {
        "command": "claudeLimitMonitor.clear",
        "title": "Claude Limit Monitor: Clear History"
      }
    ],
    "configuration": {
      "title": "Claude Limit Monitor",
      "properties": {
        "claudeLimitMonitor.proxyPort": {
          "type": "number",
          "default": 8919,
          "description": "Local proxy port for intercepting API traffic"
        },
        "claudeLimitMonitor.targetHosts": {
          "type": "array",
          "default": [
            "api.anthropic.com"
          ],
          "description": "Hostnames to monitor"
        },
        "claudeLimitMonitor.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the proxy when VS Code opens"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-limit-monitor",
          "title": "Claude Limit Monitor",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "claude-limit-monitor": [
        {
          "id": "claudeLimitMonitor.statusView",
          "name": "Rate Limits"
        },
        {
          "id": "claudeLimitMonitor.historyView",
          "name": "Request History"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "selfsigned": "^5.5.0"
  }
}
