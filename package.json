{
  "name": "claude-rate-monitor",
  "displayName": "Claude Rate Limit Monitor",
  "description": "Monitor Anthropic API rate limit headers from Claude Code CLI traffic",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claudeRateMonitor.start",
        "title": "Claude Rate Monitor: Start Proxy"
      },
      {
        "command": "claudeRateMonitor.stop",
        "title": "Claude Rate Monitor: Stop Proxy"
      },
      {
        "command": "claudeRateMonitor.showDashboard",
        "title": "Claude Rate Monitor: Show Dashboard"
      },
      {
        "command": "claudeRateMonitor.clear",
        "title": "Claude Rate Monitor: Clear History"
      }
    ],
    "configuration": {
      "title": "Claude Rate Monitor",
      "properties": {
        "claudeRateMonitor.proxyPort": {
          "type": "number",
          "default": 8919,
          "description": "Local proxy port for intercepting API traffic"
        },
        "claudeRateMonitor.targetHosts": {
          "type": "array",
          "default": ["api.anthropic.com"],
          "description": "Hostnames to monitor"
        },
        "claudeRateMonitor.autoStart": {
          "type": "boolean",
          "default": false,
          "description": "Automatically start the proxy when VS Code opens"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-rate-monitor",
          "title": "Claude Rate Monitor",
          "icon": "$(pulse)"
        }
      ]
    },
    "views": {
      "claude-rate-monitor": [
        {
          "id": "claudeRateMonitor.statusView",
          "name": "Rate Limits"
        },
        {
          "id": "claudeRateMonitor.historyView",
          "name": "Request History"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
